# Datenbank (Neon Postgres Connection String)
DATABASE_URL=

# Session-Signierung: mindestens 32 zufällige Zeichen, z.B. mit
# `openssl rand -hex 32` erzeugen. NIE committen, NIE wiederverwenden.
SESSION_SECRET=

# Resend (Transaktions- und Newsletter-Mails)
RESEND_API_KEY=

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
# Aus Stripe Dashboard -> Developers -> Webhooks -> Endpoint anlegen
# (Ziel-URL: https://deine-domain.de/api/stripe-webhook) -> Signing Secret
STRIPE_WEBHOOK_SECRET=

# Web Push (siehe Abschlussbericht für die generierten Werte)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:deine@email.de

# Basis-URL der Seite (für Links in Emails, Stripe Redirects, etc.)
NEXT_PUBLIC_BASE_URL=https://mz-dev.de
NEXT_PUBLIC_SITE_URL=https://mz-dev.de

# Vercel Blob (Produktbilder) - wird automatisch gesetzt, sobald im Vercel
# Dashboard unter "Storage" ein Blob-Store mit dem Projekt verbunden wird.
# BLOB_READ_WRITE_TOKEN=
